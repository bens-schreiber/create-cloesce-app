{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "nodenext",
    "types": ["@cloudflare/workers-types", "@cloudflare/vitest-pool-workers/types"],
    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "paths": {
      "@api/*": ["./src/api/*"],
      "@cloesce/*": ["./.cloesce/*"],
    },
    "outDir": "dist",
  },
  "include": [".cloesce/*.ts", "src/api/**/*.ts", "tests/**/*.ts", "migrations/**/*.ts"],
}
